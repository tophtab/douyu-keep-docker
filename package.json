{
  "name": "douyu-keep-just-works",
  "version": "1.6.0",
  "description": "斗鱼粉丝牌保活工具，it just works.",
  "author": "tophtab",
  "contributors": [
    {
      "name": "Curtion"
    }
  ],
  "license": "MIT",
  "repository": "https://github.com/tophtab/douyu-keep-just-works.git",
  "main": "build/main/main.js",
  "scripts": {
    "dev": "node scripts/dev-server.js",
    "lint": "eslint . --ext .js,.ts,.vue",
    "type-check": "tsc -p tsconfig.docker.json --noEmit && tsc -p src/main/tsconfig.json --noEmit && vue-tsc -p src/renderer/tsconfig.json --noEmit",
    "test": "npm run verify:wsl",
    "build:compile": "node scripts/build.js",
    "build": "npm run build:compile && electron-builder",
    "build:win": "npm run build:compile && electron-builder --win",
    "build:mac": "npm run build:compile && electron-builder --mac",
    "build:linux": "npm run build:compile && electron-builder --linux",
    "build:docker": "tsc -p tsconfig.docker.json",
    "verify:wsl": "npm run build:compile && npm run build:docker",
    "up": "taze major -I"
  },
  "dependencies": {
    "auto-launch": "^5.0.6",
    "axios": "^1.4.0",
    "cron": "^2.4.0",
    "cron-parser": "^4.8.1",
    "dayjs": "^1.11.9",
    "electron-store": "^8.1.0",
    "express": "^4.22.1",
    "nprogress": "^0.2.0",
    "pinia": "^2.1.6",
    "puppeteer": "^21.0.0",
    "vue": "^3.3.4",
    "vue-router": "4.2.4",
    "vuetify": "^3.3.12"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^0.40.2",
    "@iconify-json/bx": "^1.1.7",
    "@iconify-json/carbon": "^1.1.19",
    "@mdi/font": "^7.2.96",
    "@types/auto-launch": "^5.0.2",
    "@types/express": "^4.17.25",
    "@types/nprogress": "^0.2.0",
    "@vitejs/plugin-vue": "^4.2.3",
    "chalk": "^4.1.2",
    "chokidar": "^3.5.3",
    "daisyui": "^3.5.1",
    "electron": "^25.4.0",
    "electron-builder": "^24.6.3",
    "eslint": "^8.46.0",
    "eslint-plugin-vue": "^9.17.0",
    "sass": "^1.64.2",
    "taze": "^0.11.2",
    "typescript": "^5.1.6",
    "unocss": "^0.54.3",
    "vite": "^4.4.9",
    "vue-tsc": "^3.2.6"
  }
}
